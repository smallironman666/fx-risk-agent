# =============================================================================
# 0G Network Configuration — choose ONE of (Galileo testnet | Aristotle mainnet)
# =============================================================================
PRIVATE_KEY=your_wallet_private_key_here

# --- Galileo Testnet (Chain ID 16602) — uncomment to use ---
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# --- Aristotle Mainnet (Chain ID 16661) — uncomment to use ---
# OG_RPC_URL=https://evmrpc.0g.ai
# OG_CHAIN_ID=16661
# OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# AI Backend 选择: doubao (默认) | 0g-compute
AI_BACKEND=doubao

# Doubao / Volcengine Ark (OpenAI-compatible)
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=your_api_key_here
AI_MODEL=doubao-seed-2-0-pro-260215

# 0G Compute (when AI_BACKEND=0g-compute)
ZG_COMPUTE_PROVIDER=
ZG_COMPUTE_TEE=true

# Alert Webhook (Slack/DingTalk/custom, leave empty for terminal-only alerts)
ALERT_WEBHOOK_URL=

# Contracts on 0G Galileo Testnet (filled after deployment)
FX_RISK_ORACLE_ADDRESS=
FX_RISK_ORACLE_V2_ADDRESS=
AGENT_INFT_ADDRESS=
AGENT_TOKEN_ID=

# ===== Chainlink Data Streams (L0 data source, optional) =====
# 只需要设置 API_KEY 和 USER_SECRET 即可启用；未设置时本层静默跳过，L1-L3 依然工作。
# Dragon (0G DevRel) 2026-04-17 确认：Data Streams 在 Galileo testnet + Aristotle
# mainnet 都可用，Verifier Proxy 已部署；需要单独申请 API access：
#   https://chain.link/contact  或 docs.chain.link/data-streams 的 "Talk to an expert"
CHAINLINK_API_KEY=
CHAINLINK_USER_SECRET=
# Testnet: https://api.testnet-dataengine.chain.link
# Mainnet: https://api.dataengine.chain.link
CHAINLINK_ENDPOINT=https://api.testnet-dataengine.chain.link
CHAINLINK_WS_ENDPOINT=wss://ws.testnet-dataengine.chain.link
# Feed 映射，格式: PAIR=FEED_ID, 逗号分隔（拿到 feed IDs 后填）
# 例：CHAINLINK_FEEDS=EUR/USD=0xfeed1,GBP/USD=0xfeed2,AUD/USD=0xfeed3,USD/CNH=0xfeed4
CHAINLINK_FEEDS=
