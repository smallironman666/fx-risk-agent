# 0G Galileo Testnet Configuration
PRIVATE_KEY=your_wallet_private_key_here
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# AI Backend 选择: doubao (默认) | 0g-compute
AI_BACKEND=doubao

# Doubao / Volcengine Ark (OpenAI-compatible)
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=your_api_key_here
AI_MODEL=doubao-seed-2-0-pro-260215

# 0G Compute (when AI_BACKEND=0g-compute)
ZG_COMPUTE_PROVIDER=
ZG_COMPUTE_TEE=true

# Alert Webhook (Slack/DingTalk/custom, leave empty for terminal-only alerts)
ALERT_WEBHOOK_URL=

# Contracts on 0G Galileo Testnet (filled after deployment)
FX_RISK_ORACLE_ADDRESS=
FX_RISK_ORACLE_V2_ADDRESS=
AGENT_INFT_ADDRESS=
AGENT_TOKEN_ID=
