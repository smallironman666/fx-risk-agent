{
  "name": "fx-risk-agent",
  "version": "0.1.0",
  "description": "AI-powered FX Risk Monitoring Agent with on-chain audit trail via 0G Storage & Chain",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "agent": "ts-node src/index.ts",
    "deploy": "forge script script/Deploy.s.sol --rpc-url $OG_RPC_URL --broadcast --private-key $PRIVATE_KEY --legacy --with-gas-price 3000000000",
    "deploy-v2": "forge script script/DeployOracleV2.s.sol --rpc-url $OG_RPC_URL --broadcast --private-key $PRIVATE_KEY --legacy --with-gas-price 3000000000",
    "deploy-agent": "forge script script/DeployAgentINFT.s.sol --rpc-url $OG_RPC_URL --broadcast --private-key $PRIVATE_KEY --legacy --with-gas-price 3000000000",
    "mint-agent": "ts-node src/tools/mintAgent.ts",
    "bootstrap-compute": "ts-node src/tools/bootstrap0gCompute.ts",
    "fetch-log": "ts-node src/tools/fetchLog.ts",
    "claim-faucets": "ts-node src/tools/claimFaucets.ts",
    "test:sol": "forge test -vv",
    "test:ts": "ts-node --project test/ts/tsconfig.json test/ts/analyzer.test.ts",
    "test": "npm run test:sol && npm run test:ts",
    "compile": "forge build"
  },
  "keywords": [
    "0G",
    "AI-Agent",
    "FX",
    "DeFi",
    "risk-management",
    "web3"
  ],
  "author": "0xSmallironman",
  "license": "MIT",
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.1",
    "@0glabs/0g-serving-broker": "^0.7.4",
    "@anthropic-ai/sdk": "^0.87.0",
    "@chainlink/data-streams-sdk": "^1.2.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.1",
    "ethers": "6.13.1",
    "openai": "^6.34.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
